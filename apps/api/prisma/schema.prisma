// Đăng kiểm Predictor — database schema
// Run: pnpm --filter @dangkiem/api db:migrate

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =========================================================
// Identity
// =========================================================

enum UserRole {
  USER
  FLEET_ADMIN
  PROXY_WORKER
  ADMIN
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  fullName      String
  phone         String
  role          UserRole @default(USER)
  fleetId       String?
  fleet         Fleet?   @relation(fields: [fleetId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  vehicles      Vehicle[]
  bookings      Booking[]
  proxyJobsAsCustomer ProxyJob[] @relation("ProxyCustomer")
  proxyJobsAsWorker   ProxyJob[] @relation("ProxyWorker")
  refreshTokens RefreshToken[]
  payments      Payment[]
  queueReports  CrowdsourcedQueueReport[]
  notifications Notification[]

  @@index([fleetId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// =========================================================
// Fleets (B2B)
// =========================================================

model Fleet {
  id           String   @id @default(cuid())
  name         String
  taxCode      String   @unique
  contactName  String
  contactPhone String
  contactEmail String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  members   User[]
  vehicles  Vehicle[]
}

// =========================================================
// Inspection centers
// =========================================================

enum City {
  HN
  HCM
}

enum LaneType {
  LIGHT       // xe con
  HEAVY       // xe tải, xe khách
  MIXED
}

model Center {
  id           String   @id @default(cuid())
  code         String   @unique // e.g. "29-03V"
  name         String
  city         City
  district     String
  address      String
  latitude     Float
  longitude    Float
  phone        String
  openTime     String   @default("07:30") // "HH:MM"
  closeTime    String   @default("17:00")
  daysClosed   Int[]    @default([0]) // 0=Sun, 6=Sat
  laneCount    Int      @default(2)
  capacityPerHour Int   @default(12)
  supportedVehicleTypes String[] @default(["car", "truck", "bus"])
  suspended    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  lanes        Lane[]
  slots        Slot[]
  bookings     Booking[]
  proxyJobs    ProxyJob[]
  liveStatuses CenterLiveStatus[]
  waitSamples  WaitSample[]
  queueReports CrowdsourcedQueueReport[]

  @@index([city])
  @@index([suspended])
}

model Lane {
  id        String   @id @default(cuid())
  centerId  String
  center    Center   @relation(fields: [centerId], references: [id], onDelete: Cascade)
  laneType  LaneType
  laneNumber Int
  active    Boolean  @default(true)

  @@unique([centerId, laneNumber])
}

model CenterLiveStatus {
  id            String   @id @default(cuid())
  centerId      String   @unique
  center        Center   @relation(fields: [centerId], references: [id], onDelete: Cascade)
  queueLength   Int      @default(0)
  activeLanes   Int      @default(0)
  lastUpdatedAt DateTime @default(now())
}

// =========================================================
// Vehicles
// =========================================================

model Vehicle {
  id                String   @id @default(cuid())
  plateNumber       String   @unique
  vehicleType       String   // car|truck|bus|specialized
  brand             String
  model             String
  yearOfManufacture Int
  vin               String?
  temExpiresAt      DateTime?
  ownerId           String
  owner             User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  fleetId           String?
  fleet             Fleet?   @relation(fields: [fleetId], references: [id], onDelete: SetNull)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  bookings  Booking[]
  proxyJobs ProxyJob[]
  notifications Notification[]

  @@index([ownerId])
  @@index([fleetId])
  @@index([temExpiresAt])
}

// =========================================================
// Slots & Bookings
// =========================================================

model Slot {
  id          String   @id @default(cuid())
  centerId    String
  center      Center   @relation(fields: [centerId], references: [id], onDelete: Cascade)
  startsAt    DateTime
  endsAt      DateTime
  capacity    Int
  bookedCount Int      @default(0)
  version     Int      @default(0) // optimistic locking

  bookings Booking[]

  @@unique([centerId, startsAt])
  @@index([startsAt])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Booking {
  id                   String        @id @default(cuid())
  bookingCode          String        @unique
  status               BookingStatus @default(CONFIRMED)
  centerId             String
  center               Center        @relation(fields: [centerId], references: [id])
  slotId               String
  slot                 Slot          @relation(fields: [slotId], references: [id])
  vehicleId            String
  vehicle              Vehicle       @relation(fields: [vehicleId], references: [id])
  userId               String
  user                 User          @relation(fields: [userId], references: [id])
  notes                String?
  predictedWaitMinutes Int?
  feeVnd               Int
  payments             Payment[]

  // Transition timestamps — drive the WaitSample ingestion
  checkedInAt          DateTime?
  inspectionStartedAt  DateTime?
  completedAt          DateTime?
  // Queue snapshot captured at check-in (for training)
  queueAheadAtArrival  Int?
  activeLanesAtArrival Int?

  // Set once a WaitSample row has been derived from this booking
  waitSampleId         String?       @unique
  waitSample           WaitSample?   @relation(fields: [waitSampleId], references: [id])

  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([userId])
  @@index([centerId, status])
  @@index([slotId])
  @@index([completedAt])
}

// =========================================================
// Proxy service (đi đăng kiểm hộ)
// =========================================================

enum ProxyJobStatus {
  REQUESTED
  ASSIGNED
  PICKED_UP
  AT_CENTER
  INSPECTED
  RETURNING
  DELIVERED
  CANCELLED
}

model ProxyJob {
  id             String         @id @default(cuid())
  status         ProxyJobStatus @default(REQUESTED)
  vehicleId      String
  vehicle        Vehicle        @relation(fields: [vehicleId], references: [id])
  customerId     String
  customer       User           @relation("ProxyCustomer", fields: [customerId], references: [id])
  workerId       String?
  worker         User?          @relation("ProxyWorker", fields: [workerId], references: [id])
  centerId       String?
  center         Center?        @relation(fields: [centerId], references: [id])
  pickupAddress  String
  pickupTime     DateTime
  contactPhone   String
  notes          String?
  feeVnd         Int
  events         ProxyJobEvent[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([customerId])
  @@index([workerId])
  @@index([status])
}

model ProxyJobEvent {
  id        String   @id @default(cuid())
  jobId     String
  job       ProxyJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  status    ProxyJobStatus
  note      String?
  createdAt DateTime @default(now())

  @@index([jobId])
}

// =========================================================
// Historical wait-time samples (for model training)
// =========================================================

model WaitSample {
  id           String   @id @default(cuid())
  centerId     String
  center       Center   @relation(fields: [centerId], references: [id], onDelete: Cascade)
  vehicleType  String
  arrivedAt    DateTime
  startedAt    DateTime
  finishedAt   DateTime?
  queueAhead   Int
  staffCount   Int
  waitMinutes  Int
  source       String   @default("ingest") // ingest|booking|crowdsourced

  // Reverse side of Booking.waitSample
  booking      Booking?

  @@index([centerId, arrivedAt])
}

// =========================================================
// Notifications — outbound queue for tem-expiry alerts etc.
// =========================================================

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
  CONSOLE
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

model Notification {
  id          String              @id @default(cuid())
  userId      String?
  user        User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  vehicleId   String?
  vehicle     Vehicle?            @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  channel     NotificationChannel
  topic       String              // e.g. "tem.expiring.30d"
  recipient   String              // email/phone/etc.
  subject     String?
  body        String
  status      NotificationStatus  @default(PENDING)
  providerRef String?
  error       String?
  sentAt      DateTime?
  createdAt   DateTime            @default(now())

  // Dedupe: only one notification per user/vehicle/topic key
  dedupeKey   String              @unique

  @@index([status])
  @@index([userId])
}

// =========================================================
// Payments — VNPay sandbox integration for booking fees
// =========================================================

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
  REFUNDED
}

enum PaymentProvider {
  VNPAY
  MOMO
  CASH
}

model Payment {
  id              String          @id @default(cuid())
  status          PaymentStatus   @default(PENDING)
  provider        PaymentProvider
  amountVnd       Int
  userId          String
  user            User            @relation(fields: [userId], references: [id])
  bookingId       String?
  booking         Booking?        @relation(fields: [bookingId], references: [id])
  // VNPay-specific. txnRef is what we send to VNPay (unique per attempt);
  // providerRef is what VNPay sends back (vnp_TransactionNo).
  txnRef          String          @unique
  providerRef     String?
  providerCode    String?         // vnp_ResponseCode
  providerMessage String?
  redirectUrl     String?         // generated VNPay URL for client to follow
  ipnReceivedAt   DateTime?
  paidAt          DateTime?
  expiresAt       DateTime
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([userId])
  @@index([bookingId])
  @@index([status])
}

// =========================================================
// Crowdsourced queue reports — primary signal for live state
// =========================================================

model CrowdsourcedQueueReport {
  id           String   @id @default(cuid())
  centerId     String
  center       Center   @relation(fields: [centerId], references: [id], onDelete: Cascade)
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  queueLength  Int      // self-reported cars ahead
  laneCount    Int?     // visible active lanes
  latitude     Float?   // for proximity verification
  longitude    Float?
  verified     Boolean  @default(false) // true if within 500m of center
  createdAt    DateTime @default(now())

  @@index([centerId, createdAt])
  @@index([userId, createdAt])
}
