# Postgres
POSTGRES_USER=dangkiem
POSTGRES_PASSWORD=dangkiem_dev_password
POSTGRES_DB=dangkiem
# If you already have Postgres on 5432, set POSTGRES_HOST_PORT=5433 (or any free port)
# and update DATABASE_URL accordingly.
POSTGRES_HOST_PORT=5432
DATABASE_URL=postgresql://dangkiem:dangkiem_dev_password@localhost:5432/dangkiem?schema=public

# API
API_PORT=4000
API_HOST=0.0.0.0
JWT_SECRET=change-me-in-prod-use-openssl-rand-hex-32
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute

# Predictor
PREDICTOR_URL=http://localhost:8000
PREDICTOR_TIMEOUT_MS=2000

# VNPay sandbox — register at https://sandbox.vnpayment.vn
# When unset, /v1/payments/vnpay/* returns 503.
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:3000/payments/return

# Notifications — unset → falls back to console (still logged)
# Resend (email): https://resend.com
RESEND_API_KEY=
EMAIL_FROM=noreply@dangkiem.app
# Esms.vn (SMS): https://esms.vn
ESMS_API_KEY=
ESMS_SECRET_KEY=

# Web
NEXT_PUBLIC_API_URL=http://localhost:4000
